# PostgreSQL
POSTGRES_DB=aureus_db
POSTGRES_USER=aureus_user
POSTGRES_PASSWORD=

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ConnectionStrings__Postgres=Host=postgres;Database=aureus_db;Username=aureus_user;Password=

# JWT
Jwt__Secret=
Jwt__Issuer=aureus-api
Jwt__Audience=aureus-client
Jwt__ExpiresInMinutes=60

# Resend
Resend__ApiKey=
Resend__FromAddress=noreply@aureus.life

# Gemini
Gemini__ApiKey=
Gemini__Model=gemini-3.1-flash-lite
Gemini__BaseUrl=https://generativelanguage.googleapis.com
